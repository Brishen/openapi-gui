{
  "name": "llm-json-schema",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Build a JSON Schema to constrain LLM output on OpenAI-compatible endpoints (vLLM, llama.cpp), with an optional React UI.",
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/src/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/core/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/src/react/index.d.ts",
      "import": "./dist/react.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:css",
    "build:css": "tailwindcss -i src/react/styles.css -o dist/styles.css --minify",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/cli": "^4.1.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.1.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  }
}
